--1. How many rows are in the names table?
SELECT COUNT(*) 
FROM names;

--Total Nuber of Rows 1957046


--2. How many total registered people appear in the dataset?
SELECT SUM(num_registered) AS total_registered
FROM names;
--Total registered 351653025


--3. Which name had the most appearances in a single year in the dataset?

SELECT  name, year, num_registered
FROM names 
ORDER BY num_registered DESC
LIMIT 1;
-- Linda had the most appearances in 1947


--4. What range of years are included?
SELECT MIN(year), MAX(year)
FROM names;
-- Years range from 1880 to 2018


--5. What year has the largest number of registrations?
SELECT SUM(num_registered) as total_registered, year
FROM names
GROUP BY year
ORDER BY total_registered DESC
LIMIT 1;
--Largest number of registered in the year 1957 with total 4200022



--6. How many different (distinct) names are contained in the dataset?
SELECT COUNT(DISTINCT name) as total_distinct_names
FROM names;
--Total 98400 distinct names contained in the data set


--7. Are there more males or more females registered?
SELECT SUM(num_registered) as total_registered, gender
FROM names
GROUP BY gender
ORDER BY total_registered DESC;
--Males(177573793) are more registered than Females(174079232)


--8. What are the most popular male and female names overall (i.e., the most total registrations)?
SELECT DISTINCT ON (gender) gender , name, SUM(num_registered) as total_registered   --DISTINCT ON picks TOP name per gender
FROM names
GROUP BY name,gender
ORDER BY gender ,total_registered DESC;


-- other way
SELECT name, SUM(num_registered) AS total_registered
FROM names
WHERE gender='F'
GROUP BY name
ORDER BY total_registered DESC
LIMIT 1;

SELECT name, SUM(num_registered) AS total_registered
FROM names
WHERE gender='M'
GROUP BY name
ORDER BY total_registered DESC
LIMIT 1;


--9. What are the most popular boy and girl names of the first decade of the 2000s (2000 - 2009)?
SELECT  name,year,SUM(num_registered) as total_registered,   --gender?
FROM names
WHERE year BETWEEN 2000 AND 2009
GROUP BY name,year
ORDER BY total_registered DESC;

-- other way
SELECT DISTINCT ON (gender) gender , name, SUM(num_registered) as total_registered   --DISTINCT ON picks TOP name per gender
FROM names
WHERE year BETWEEN 2000 AND 2009
GROUP BY name,gender
ORDER BY gender ,total_registered DESC;


--10. Which year had the most variety in names (i.e. had the most distinct names)?
SELECT  year,COUNT(DISTINCT name) as dist_names 
FROM names
GROUP BY year
ORDER BY dist_names DESC
LIMIT 1;
-- IN 2008 with 32518 distinct names

--11. What is the most popular name for a girl that starts with the letter X?
SELECT name, SUM(num_registered) as total_registered
FROM names
WHERE gender = 'F' and name ILIKE 'X%'  --ILIKE not case sensitive, LIKE case sensitive
GROUP BY name
ORDER BY total_registered DESC
LIMIT 1;
-- Ximena with 26145 registrations


--12. Write a query to find all (distinct) names that start with a 'Q' but whose second letter is not 'u'.
SELECT DISTINCT name
FROM names
WHERE name  LIKE 'Q%'
  AND name NOT LIKE '_u%'

-- by using substrings
SELECT DISTINCT name
FROM people 
WHERE name LIKE 'Q%'
 AND substring(name, 2, 1) <> 'u';
--Total 46 distinct names starts with 'Q' but not 'QU'


--13. Which is the more popular spelling between "Stephen" and "Steven"? Use a single query to answer this question.
SELECT SUM(num_registered) as total_registered, name
FROM names
WHERE name = 'Stephen' OR name = 'Steven'  --or name IN  can be used 
GROUP BY name
ORDER BY total_registered DESC;
-- 'Steven' is the most popular  

--14. Find all names that are "unisex" - that is all names that have been used both for boys and for girls.
SELECT name
FROM names
GROUP BY name
HAVING COUNT(DISTINCT gender) > 1;   --Filter names if gender counter is 2('M','F')



--15. Find all names that have made an appearance in every single year since 1880.

SELECT COUNT(DISTINCT year), name
FROM names
GROUP BY name
HAVING COUNT(DISTINCT year) = 2018-1880+1 ;    -- Count distinct years and 2018-1880+1 it includes both the years
--HAVING COUNT(DISTINCT year) > 2018-1880  ; 

--using Sub query
SELECT name
 FROM names
GROUP BY name 
HAVING count(DISTINCT year) = (
 SELECT count(DISTINCT year)
 FROM names
 );

--16. Find all names that have only appeared in one year.

SELECT  name
FROM names
GROUP BY name
HAVING COUNT(DISTINCT year) = 1 ;  

--using Sub query
SELECT name, gender
FROM names
WHERE name IN (SELECT name
FROM names
GROUP BY name
HAVING COUNT(DISTINCT year) = 1
ORDER BY name);


--17. Find all names that only appeared in the 1950s.

SELECT  name, MIN(year) as min_year, MAX(year) as max_year
FROM names
GROUP BY name
HAVING MIN(year)>= 1950 AND MAX(year)<=1959;

--18. Find all names that made their first appearance in the 2010s.

SELECT name, MIN(year) AS first_appearance
FROM names
GROUP BY name
HAVING MIN(year) BETWEEN 2010 AND 2018


--19. Find the names that have not been used in the longest.

SELECT name, MAX(year) AS last_used_year, (2026 - MAX(year)) AS years_old
FROM names
GROUP BY name
ORDER BY last_used_year ASC
LIMIT 10;



--20. Come up with a question that you would like to answer using this dataset. Then write a query to answer this question.

--Which name had been used for the greatest number of years

SELECT name, COUNT(DISTINCT year) AS total_years
FROM names
GROUP BY name
ORDER BY total_years DESC
LIMIT 20;



